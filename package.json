{
  "name": "jsonlxlsx",
  "version": "0.0.0",
  "private": true,
  "description": "JSONL-to-XLSX transformation engine",
  "type": "module",
  "main": "./src/engine.js",
  "exports": {
    ".": "./src/engine.js",
    "./reduce": "./src/reduce.js",
    "./render": "./src/render.js"
  },
  "bin": {
    "jsonlxlsx": "./src/cli.js"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/roccho-dev/jsonlxlsx.git"
  },
  "scripts": {
    "generate": "node scripts/generate-artifacts.mjs",
    "check": "node scripts/check-artifacts.mjs",
    "test": "vitest run",
    "check:exportability": "node scripts/check-exportability.js",
    "example": "node scripts/generate-example.js"
  },
  "keywords": [
    "jsonl",
    "xlsx",
    "append-only",
    "schema-driven"
  ],
  "dependencies": {
    "exceljs": "^4.3.0"
  },
  "devDependencies": {
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": "node>=18"
  }
}
