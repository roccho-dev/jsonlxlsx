{
  "name": "@jsonlxlsx/engine",
  "version": "0.2.0-hucre-backend",
  "description": "Append-only JSONL to XLSX compiler using hucre as the XLSX writer backend.",
  "type": "module",
  "main": "./src/core/index.mjs",
  "browser": "./src/adapters/browser/index.mjs",
  "exports": {
    ".": "./src/core/index.mjs",
    "./core": "./src/core/index.mjs",
    "./ports": "./src/ports/index.mjs",
    "./adapters/node": "./src/adapters/node/index.mjs",
    "./adapters/browser": "./src/adapters/browser/index.mjs",
    "./adapters/cli": "./src/adapters/cli/node.mjs"
  },
  "bin": {
    "jsonlxlsx": "./src/adapters/cli/node.mjs",
    "jsonl-xlsx-js": "./src/adapters/cli/node.mjs"
  },
  "scripts": {
    "syntax": "node tools/check-syntax.mjs",
    "lint:arch": "node tools/lint-architecture.mjs",
    "test": "node --test",
    "proof": "node tools/proof.mjs && node tools/proof-separated.mjs",
    "proof:separated": "node tools/proof-separated.mjs",
    "shiftleft": "node tools/check-syntax.mjs && node tools/lint-architecture.mjs && node --test && node tools/proof.mjs && node tools/proof-separated.mjs",
    "check:exportability": "node scripts/check-exportability.mjs"
  },
  "keywords": [
    "xlsx",
    "jsonl",
    "append-only",
    "browser",
    "node",
    "hucre"
  ],
  "license": "UNLICENSED",
  "dependencies": {
    "hucre": "0.6.1"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "src",
    "docs",
    "examples",
    "README.md",
    "THIRD_PARTY_NOTICES.md"
  ]
}
